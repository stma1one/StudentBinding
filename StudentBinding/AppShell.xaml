<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="StudentBinding.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:StudentBinding.Pages"
    Title="StudentBinding">

    <ShellContent
        Title="Student MVVM"
        ContentTemplate="{DataTemplate pages:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Control Binding"
        ContentTemplate="{DataTemplate pages:ControlBindingPage}"
        Route="ControlBindingPage" />

</Shell>
